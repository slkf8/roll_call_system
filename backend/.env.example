ROLL_CALL_DATA_DIR=
# Force packaged or source mode. Accepts 1/true/yes or 0/false/no.
# When unset, the app falls back to sys.frozen (set by PyInstaller).
ROLL_CALL_PACKAGED=
# Directory containing the built frontend assets (frontend/dist).
# Highest priority; leave empty to use sys._MEIPASS/frontend_dist when
# packaged, or <repo>/frontend/dist in dev source mode.
ROLL_CALL_FRONTEND_DIST=
ROLL_CALL_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ROLL_CALL_HOST=127.0.0.1
ROLL_CALL_PORT=8000
# --- Automatic backup (all optional; invalid values fall back to defaults) ---
# Master switch for the backup scheduler, mutation hooks, rolling latest and
# daily snapshots.
ROLL_CALL_ENABLE_BACKUP=1
# Independent guard: refuse to start (instead of creating an empty DB) when
# app.db is missing but backups exist. Controlled separately from backups.
ROLL_CALL_ENABLE_PRIMARY_DB_PREFLIGHT=1
# Quiet period after the last mutation commit before refreshing app_latest.db.
ROLL_CALL_BACKUP_DEBOUNCE_SECONDS=30
# Force a refresh at least this often while mutations keep arriving.
ROLL_CALL_BACKUP_MAX_WAIT_SECONDS=300
# Local time (HH:MM) for the immutable daily snapshot.
ROLL_CALL_DAILY_BACKUP_TIME=03:00
# Calendar days of daily snapshots to keep.
ROLL_CALL_BACKUP_RETENTION_DAYS=30
