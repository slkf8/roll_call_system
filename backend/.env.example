ROLL_CALL_DATA_DIR=
# Force packaged or source mode. Accepts 1/true/yes or 0/false/no.
# When unset, the app falls back to sys.frozen (set by PyInstaller).
ROLL_CALL_PACKAGED=
# Directory containing the built frontend assets (frontend/dist).
# Highest priority; leave empty to use sys._MEIPASS/frontend_dist when
# packaged, or <repo>/frontend/dist in dev source mode.
ROLL_CALL_FRONTEND_DIST=
ROLL_CALL_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ROLL_CALL_HOST=127.0.0.1
ROLL_CALL_PORT=8000
