# macOS
.DS_Store

# 環境/機密
.env
.env.*
*.local
!.env.example
!**/.env.example

# Claude Code local-only overrides
.claude/settings.local.json

# Local test artifacts (real templates etc., not for git)
test_artifacts/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.venv-build/
.envrc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Frontend
node_modules/
dist/
.vite/
*.log

# PyInstaller output
backend/build/
backend/dist/

# Portable release folder (produced by scripts/package_release.sh)
release/

# 匯出物（通常是產出，不建議進版控）
exports/*
!exports/.gitkeep

# Excel 檔案不進版控（避免散佈真實官方模板或內含真實學生資料）
*.xlsx
*.xls
*.xlsm

# DB（全域防呆：任何 SQLite / 備份檔都不進版控，含 repo 根的 app_backup.db）
*.db
*.db.tmp
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
backend/data/*.db
backend/data/*.db-journal
backend/data/*.sqlite
backend/data/*.sqlite3
backend/data/*.lock
backend/data/backups/
backend/__pycache__/
backend/.pytest_cache/
