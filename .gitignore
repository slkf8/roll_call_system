# macOS
.DS_Store

# 環境/機密
.env
.env.*
*.local
!.env.example
!**/.env.example

# Claude Code local-only overrides
.claude/settings.local.json

# Local test artifacts (real templates etc., not for git)
test_artifacts/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.envrc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Frontend
node_modules/
dist/
.vite/
*.log

# 匯出物（通常是產出，不建議進版控）
exports/*
!exports/.gitkeep

# DB（若你之後用 SQLite）
*.sqlite
*.sqlite3
backend/data/*.db
backend/data/*.db-journal
backend/data/*.sqlite
backend/data/*.sqlite3
backend/__pycache__/
backend/.pytest_cache/
